{
  "name": "pulsewatch",
  "version": "1.0.0",
  "description": "API Monitoring SaaS Dashboard - Monitor your APIs, get alerted about downtime",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "worker",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev:worker": "cd worker && npm run dev",
    "build": "npm run build:shared && npm run build:server && npm run build:worker && npm run build:client",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "build:worker": "cd worker && npm run build",
    "build:shared": "cd shared && npm run build",
    "test": "npm run test:server && npm run test:client",
    "test:server": "cd server && npm test",
    "test:client": "cd client && npm test",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "npm run typecheck:shared && npm run typecheck:server && npm run typecheck:worker && npm run typecheck:client",
    "typecheck:shared": "cd shared && tsc --noEmit",
    "typecheck:server": "cd server && tsc --noEmit",
    "typecheck:worker": "cd worker && tsc --noEmit",
    "typecheck:client": "cd client && tsc --noEmit",
    "db:migrate": "cd server && npm run db:migrate",
    "db:seed": "cd server && npm run db:seed",
    "db:reset": "cd server && npm run db:reset",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
